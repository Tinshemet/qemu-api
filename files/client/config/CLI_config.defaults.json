{
  "text_color":              "#aaaaaa",
  "font_size":               13,
  "font_family":             "Monospace",
  "wrap_width":              120,
  "terminal_rows":           44,
  "terminal_cols":           200,
  "startup_delay_s":         0.12,
  "autostart_poll_count":    20,
  "autostart_poll_interval_s": 0.5,
  "log_path":                "/tmp/gorgon-orchestrator.log",
  "token_file":              "~/.gorgon.token",
  "session_file":            "~/.qemu_vms/.chat_session_id",
  "vm_base_dir":             "~/.qemu_vms",
  "default_vnc_port":        5900,

  "spawn_host":              "0.0.0.0",
  "spawn_log_level":         "warning",
  "uvicorn_app":             "orchestrator.http.api_server:app",

  "color_header_fg":         "WHITE",
  "color_header_bg":         "BLUE",
  "color_cyan":              "CYAN",
  "color_green":             "GREEN",
  "color_red":               "RED",
  "color_yellow":            "YELLOW",
  "color_bold":              "WHITE",
  "custom_color_slot":       16,
  "dim_fallback_slot":       8,
  "color_fallback_rgb":      [667, 667, 667],

  "color_pair_header":       1,
  "color_pair_cyan":         2,
  "color_pair_green":        3,
  "color_pair_red":          4,
  "color_pair_dim":          5,
  "color_pair_yellow":       6,
  "color_pair_bold":         7,

  "glyph_running":           "● ",
  "glyph_stopped":           "○ ",
  "spinner_frames":          "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏",
  "hint_line":               "  list  system  profiles  templates  drift  /clear  help  q=quit",

  "shortcut_list":           ["list", "vms", "ls"],
  "shortcut_system":         ["system"],
  "shortcut_profiles":       ["profiles"],
  "shortcut_templates":      ["templates"],
  "shortcut_drift":          ["drift"],
  "shortcut_clear":          ["clear session", "forget", "/clear"],
  "shortcut_help":           ["help", "?", "/help"],
  "exit_commands":           ["exit", "quit", "q", "bye"]
}
