  "slot_patterns": {
    "name": [
      "\\bcalled ([\\w][\\w\\-_\\.]*)",
      "\\bnamed ([\\w][\\w\\-_\\.]*)",
      "\\bvm ([\\w][\\w\\-_\\.]*)",
      "\\bon ([\\w][\\w\\-_\\.]*)",
      "\\bfor ([\\w][\\w\\-_\\.]*)",
      "\\b(?:start|launch|run|boot|stop|halt|kill|delete|remove|destroy|clone|monitor|watch|resize|snapshot|restore|revert|configure|update|show|open|display) ([\\w][\\w\\-_\\.]+)",
      "\\b(?:shut down|power off|turn off|bring up|spin up|fire up|set up|back up) ([\\w][\\w\\-_\\.]+)",
      "\"([\\w][\\w\\-_\\.]*)\"",
      "'([\\w][\\w\\-_\\.]*)'",
      "([\\w]+[\\-_][\\w][\\w\\-_\\.]*)"
    ],
    "snap_name": [
      "\\bsnapshot ([\\w][\\w\\-_\\.]*)",
      "\\bsnap ([\\w][\\w\\-_\\.]*)",
      "\\bcalled ([\\w][\\w\\-_\\.]*)",
      "\\bnamed ([\\w][\\w\\-_\\.]*)"
    ],
    "os_type":      ["linux", "windows", "macos", "ubuntu", "debian",
                     "fedora", "arch", "kali", "centos", "win",
                     "mint", "rhel", "suse", "osx", "darwin", "mac",
                     "freebsd", "openbsd", "android"],
    "network_mode": ["nat", "bridge"],
    "new_name": [
      "\\bto ([\\w][\\w\\-_\\.]*)",
      "\\bas ([\\w][\\w\\-_\\.]*)",
      "\\binto ([\\w][\\w\\-_\\.]*)",
      "\\bcalled ([\\w][\\w\\-_\\.]*)",
      "\\bnamed ([\\w][\\w\\-_\\.]*)"
    ]
  },

