  "help_sections": [
    {"title": "VM Commands", "commands": [
      {"label": "launch <vm>", "text": "Start a VM",                   "tools": ["launch_vm"]},
      {"label": "stop <vm>",   "text": "Graceful stop (SIGTERM)",      "tools": ["stop_vm"]},
      {"label": "kill <vm>",   "text": "Force-kill (SIGKILL)",         "tools": ["stop_vm"]},
      {"label": "stopall",     "text": "Stop all running VMs",         "tools": ["stop_vm"]},
      {"label": "list",        "text": "Print VM names in status line", "tools": ["list_vms"]}
    ]},
    {"title": "Server Commands (local only)", "commands": [
      {"label": "start-server", "text": "Start the orchestrator on this machine",  "tools": null},
      {"label": "restart",      "text": "Restart the orchestrator (stop + start)",  "tools": null},
      {"label": "shutdown",     "text": "SIGTERM the orchestrator on this machine", "tools": null},
      {"label": "kill-server",  "text": "SIGKILL the orchestrator on this machine", "tools": null},
      {"label": "status",       "text": "Show orchestrator reachability + VM counts", "tools": null}
    ]},
    {"title": "Navigation", "commands": [
      {"label": "help",     "text": "Show this overlay  (any key to close)", "tools": null},
      {"label": "q / Esc",  "text": "Quit the admin TUI",                    "tools": null}
    ]}
  ]
}
