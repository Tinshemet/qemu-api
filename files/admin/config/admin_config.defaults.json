  "label_vm":                "VM",
  "label_status":            "STATUS",
  "label_cpu":               "CPU",
  "label_ram":               "RAM",
  "label_os":                "OS",
  "label_time":              "TIME",
  "label_tool":              "TOOL",
  "label_target":            "TARGET",
  "label_result":            "RESULT",
  "label_ms":                "MS",

