{
  "text_color":              "#aaaaaa",
  "font_size":               13,
  "font_family":             "Monospace",
  "refresh_rate_s":          1.0,
  "default_port":            8080,
  "log_path":                "/tmp/gorgon-orchestrator.log",
  "events_display_limit":    200,

  "default_orchestrator_url": "http://localhost:8080",
  "token_file":              "~/.gorgon.token",

  "execute_path":            "/execute",
  "health_path":             "/health",
  "events_path":             "/events",
  "tool_stop":               "stop_vm",
  "tool_launch":             "launch_vm",
  "tool_list":               "list_vms",
  "uvicorn_app":             "orchestrator.http.api_server:app",
  "pgrep_pattern":           "api_server",

  "http_timeout_s":          5,
  "health_timeout_s":        2,
  "health_cache_s":          2.0,

  "spawn_host":              "0.0.0.0",
  "spawn_log_level":         "warning",
  "startup_wait_ticks":      20,
  "startup_wait_interval_s": 0.3,
  "restart_grace_s":         5,
  "restart_poll_interval_s": 0.2,
  "restart_kill_wait_s":     0.3,

  "term_rows":               52,
  "term_cols":               200,
  "startup_delay_s":         0.12,
  "frame_interval_s":        0.05,

  "color_header_fg":         "WHITE",
  "color_header_bg":         "BLUE",
  "color_cyan":              "CYAN",
  "color_green":             "GREEN",
  "color_red":               "RED",
  "color_yellow":            "YELLOW",
  "dim_fallback_slot":       8,
  "custom_color_slot":       16,
