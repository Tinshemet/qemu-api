{
  "vm_base": "~/.qemu_vms",
  "valid_machine_types": [
    "q35",
    "pc",
    "pc-i440fx",
    "microvm",
    "virt",
    "raspi3b",
    "raspi2b",
    "raspi0"
  ],
  "arm_cpu_prefixes": [
    "cortex",
    "arm1",
    "arm9",
    "arm11"
  ],
  "create_vm_defaults": {
    "disk_size_gb": 60,
    "disk_format": "qcow2",
    "network_mode": "nat",
    "bridge": "virbr0",
    "stealth_slirp_subnet": "192.168.1.0/24"
  },
  "tool_defaults": {
    "snap_name": "snap1",
    "log_lines": 50
  },
  "generic_os_names": [
    "linux",
    "windows",
    "macos",
    "other",
    ""
  ],
  "arm_iso_keywords": ["arm64", "aarch64", "arm_"],
  "x86_iso_keywords": ["amd64", "x86_64", "x64", "i386", "i686"]
}
